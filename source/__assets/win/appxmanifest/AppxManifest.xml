              <uap:FileType>.fff</uap:FileType>
              <uap:FileType>.fits</uap:FileType>
              <uap:FileType>.flif</uap:FileType>
              <uap:FileType>.gif</uap:FileType>
              <uap:FileType>.gpr</uap:FileType>
              <uap:FileType>.hdp</uap:FileType>
              <uap:FileType>.hdr</uap:FileType>
              <uap:FileType>.heic</uap:FileType>
              <uap:FileType>.heif</uap:FileType>
              <uap:FileType>.hif</uap:FileType>
              <uap:FileType>.ico</uap:FileType>
              <uap:FileType>.iiq</uap:FileType>
              <uap:FileType>.jfif</uap:FileType>
              <uap:FileType>.jp2</uap:FileType>
              <uap:FileType>.jpe</uap:FileType>
              <uap:FileType>.jpeg</uap:FileType>
              <uap:FileType>.jpg</uap:FileType>
