              <uap:FileType>.srf</uap:FileType>
              <uap:FileType>.srw</uap:FileType>
              <uap:FileType>.svg</uap:FileType>
              <uap:FileType>.svgz</uap:FileType>
              <uap:FileType>.tga</uap:FileType>
              <uap:FileType>.tif</uap:FileType>
              <uap:FileType>.tiff</uap:FileType>
              <uap:FileType>.wdp</uap:FileType>
              <uap:FileType>.webp</uap:FileType>
              <uap:FileType>.wmf</uap:FileType>
              <uap:FileType>.wpg</uap:FileType>
              <uap:FileType>.x3f</uap:FileType>
              <uap:FileType>.xbm</uap:FileType>
              <uap:FileType>.xpm</uap:FileType>
            </uap:SupportedFileTypes>
          </uap:FileTypeAssociation>
        </uap:Extension>
        <desktop:Extension Category="windows.fullTrustProcess" Executable="ExifGlass\ExifGlass.exe" />
        <uap3:Extension Category="windows.appExecutionAlias" EntryPoint="Windows.FullTrustApplication" Executable="ExifGlass\ExifGlass.exe">
          <uap3:AppExecutionAlias>
            <desktop:ExecutionAlias Alias="ExifGlass.exe" />
          </uap3:AppExecutionAlias>
        </uap3:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
    <rescap:Capability Name="broadFileSystemAccess" />
  </Capabilities>
</Package>
