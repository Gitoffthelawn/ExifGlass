<?xml version="1.0" encoding="utf-8"?>
<!--
  AppxManifest template for the ExifGlass Windows head (ExifGlass.Win32).

  The {{...}} placeholders are filled in at pack time by script-pack-win-msix.ps1:
    {{IDENTITY_NAME}}          package identity name (e.g. DuongDieuPhap.ExifGlass)
    {{PUBLISHER}}              the EXACT Subject DN of the signing certificate
                               (or a CN=... placeholder for an unsigned build)
    {{PUBLISHER_DISPLAY_NAME}} human-readable publisher shown in the installer
    {{VERSION}}                4-part package version, Major.Minor.Build.0
    {{ARCH}}                   x64 | arm64

  The unqualified logo names below (e.g. Assets\EXIFGLASS-Square150x150Logo.png)
  resolve to the scale/targetsize-qualified files in Assets\ via resources.pri,
  which makepri builds from that folder at pack time. Regenerate the Assets\ set
  from the app logo with script-generate-msix-assets.ps1.
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  xmlns:desktop="http://schemas.microsoft.com/appx/manifest/desktop/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap uap3 desktop rescap">

  <Identity Name="{{IDENTITY_NAME}}" Publisher="{{PUBLISHER}}" Version="{{VERSION}}" ProcessorArchitecture="{{ARCH}}" />

  <Properties>
    <DisplayName>ExifGlass</DisplayName>
    <PublisherDisplayName>{{PUBLISHER_DISPLAY_NAME}}</PublisherDisplayName>
    <Description>EXIF Metadata Viewing Tool</Description>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Applications>
    <Application Id="EXIFGLASS" Executable="ExifGlass\ExifGlass.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        BackgroundColor="transparent"
        DisplayName="ExifGlass"
        Square150x150Logo="Assets\EXIFGLASS-Square150x150Logo.png"
        Square44x44Logo="Assets\EXIFGLASS-Square44x44Logo.png"
        Description="EXIF Metadata Viewing Tool">
        <uap:DefaultTile
          Wide310x150Logo="Assets\EXIFGLASS-Wide310x150Logo.png"
          Square310x310Logo="Assets\EXIFGLASS-Square310x310Logo.png"
          Square71x71Logo="Assets\EXIFGLASS-Square71x71Logo.png" />
      </uap:VisualElements>
      <Extensions>
        <uap:Extension Category="windows.fileTypeAssociation" EntryPoint="Windows.FullTrustApplication" Executable="ExifGlass\ExifGlass.exe">
          <uap:FileTypeAssociation Name="exifglass.assocfiles">
            <uap:SupportedFileTypes>
              <uap:FileType>.3fr</uap:FileType>
              <uap:FileType>.apng</uap:FileType>
              <uap:FileType>.ari</uap:FileType>
              <uap:FileType>.arw</uap:FileType>
