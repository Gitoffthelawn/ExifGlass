{
  // Tasks assume the workspace folder is this `source/` directory. Each task is a thin wrapper
  // around a platform script under __assets/<platform>/ (grouped: __assets/win, __assets/linux).
  "version": "2.0.0",
  "tasks": [
    // --- ExifTool: compile the self-contained binary (Perl embedded via PAR::Packer) -----------
    // Linux/macOS only -- pp bundles the host Perl and can't cross-build; run these on Linux or WSL
    // (per target architecture). Requires PAR::Packer + ExifTool's helper modules (libperl-dev
    // supplies the Perl headers pp links its C loader against; build-essential alone is not enough):
    //   sudo apt-get install -y perl cpanminus build-essential libperl-dev
    //   sudo cpanm --notest PAR::Packer Archive::Zip Compress::Zlib Digest::SHA \
    //                       IO::Compress::Bzip2 Time::Piece IO::String
    // Output is cached per-RID under __assets/exiftool/unix/build/<rid>/ and picked up by the
    // matching build/publish task (via ExifGlass.Linux.csproj). Skips if already built; the app
    // tasks below depend on it, so pass "--force" to build-exiftool.sh by hand to force a rebuild.
    {
      "label": "build-exiftool-linux-x64",
      "type": "process",
      "command": "bash",
      "args": [
        "${workspaceFolder}/__assets/linux/build-exiftool.sh",
        "x64"
      ],
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "build-exiftool-linux-arm64",
      "type": "process",
      "command": "bash",
      "args": [
        "${workspaceFolder}/__assets/linux/build-exiftool.sh",
        "arm64"
      ],
      "problemMatcher": [],
      "group": "build"
    },


    // --- Build tasks (Debug) -------------------------------------------------------------------
    {
      "label": "build-win-x64",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/__assets/win/build.ps1",
        "x64"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "build-win-arm64",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/__assets/win/build.ps1",
        "arm64"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      // Compiles the self-contained ExifTool first, then the app; the csproj bundles that binary.
      "label": "build-linux-x64",
      "type": "process",
      "command": "bash",
      "args": [
        "${workspaceFolder}/__assets/linux/build.sh",
        "x64"
      ],
      "problemMatcher": "$msCompile",
      "dependsOn": [
        "build-exiftool-linux-x64"
      ],
      "dependsOrder": "sequence",
      "group": "build"
    },
    {
      "label": "build-linux-arm64",
      "type": "process",
      "command": "bash",
      "args": [
        "${workspaceFolder}/__assets/linux/build.sh",
        "arm64"
      ],
      "problemMatcher": "$msCompile",
      "dependsOn": [
        "build-exiftool-linux-arm64"
      ],
      "dependsOrder": "sequence",
      "group": "build"
    },


    // --- Publish tasks (Release; self-contained NativeAOT is configured in the csprojs) --------
    // NativeAOT can't cross-compile, so publish each head on its own OS (Linux/WSL for linux-*).
    {
      "label": "publish-win-x64",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/__assets/win/publish.ps1",
        "x64"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "publish-win-arm64",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/__assets/win/publish.ps1",
        "arm64"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "publish-linux-x64",
      "type": "process",
      "command": "bash",
      "args": [
        "${workspaceFolder}/__assets/linux/publish.sh",
        "x64"
      ],
      "problemMatcher": "$msCompile",
      "dependsOn": [
        "build-exiftool-linux-x64"
      ],
      "dependsOrder": "sequence",
      "group": "build"
    },
    {
      "label": "publish-linux-arm64",
      "type": "process",
      "command": "bash",
      "args": [
        "${workspaceFolder}/__assets/linux/publish.sh",
        "arm64"
      ],
      "problemMatcher": "$msCompile",
      "dependsOn": [
        "build-exiftool-linux-arm64"
      ],
      "dependsOrder": "sequence",
      "group": "build"
    }
  ]
}
