{
  // Tasks assume the workspace folder is this `source/` directory. Each task is a thin wrapper
  // around a platform script under __assets/<platform>/ (grouped: __assets/win, __assets/linux).
  "version": "2.0.0",
  "tasks": [
    // ExifTool: compile the self-contained binary (Perl via PAR::Packer; Linux only), cached and
    // reused. Prerequisites + usage are documented in __assets/linux/build-exiftool.sh.
    {
      "label": "build-exiftool-linux-x64",
      "type": "process",
      "command": "bash",
      "args": [
        "${workspaceFolder}/__assets/linux/build-exiftool.sh",
        "x64"
      ],
      "problemMatcher": [],
      "group": "build"
    },


    // --- Build tasks (Debug) -------------------------------------------------------------------
    {
      "label": "build-win-x64",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/__assets/win/build.ps1",
        "x64"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "build-win-arm64",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/__assets/win/build.ps1",
        "arm64"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      // Compiles the self-contained ExifTool first, then the app; the csproj bundles that binary.
      "label": "build-linux-x64",
      "type": "process",
      "command": "bash",
      "args": [
        "${workspaceFolder}/__assets/linux/build.sh",
        "x64"
      ],
      "problemMatcher": "$msCompile",
      "dependsOn": [
        "build-exiftool-linux-x64"
      ],
      "dependsOrder": "sequence",
      "group": "build"
    },
    {
      // macOS bundles the ExifTool Perl script + lib/ (PAR binaries can't be notarized), so there
      // is no build-exiftool step; the csproj bundles the script directly.
      "label": "build-mac-arm64",
      "type": "process",
      "command": "bash",
      "args": [
        "${workspaceFolder}/__assets/mac/build.sh",
        "arm64"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },


    // --- Publish tasks (Release; self-contained NativeAOT is configured in the csprojs) --------
    // NativeAOT can't cross-compile, so publish each head on its own OS (Linux/WSL for linux-*).
    {
      "label": "publish-win-x64",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/__assets/win/publish.ps1",
        "x64"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "publish-win-arm64",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/__assets/win/publish.ps1",
        "arm64"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "publish-linux-x64",
      "type": "process",
      "command": "bash",
      "args": [
        "${workspaceFolder}/__assets/linux/publish.sh",
        "x64"
      ],
      "problemMatcher": "$msCompile",
      "dependsOn": [
        "build-exiftool-linux-x64"
      ],
      "dependsOrder": "sequence",
      "group": "build"
    },
    {
      // NativeAOT can't cross-compile, so run on Apple Silicon. Output: __artifacts/publish/osx-arm64.
      "label": "publish-mac-arm64",
      "type": "process",
      "command": "bash",
      "args": [
        "${workspaceFolder}/__assets/mac/publish.sh",
        "arm64"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },


    // macOS pack tasks. build the .app from a fresh publish, then produce a signed+notarized DMG
    // (Developer ID / website) or a signed .pkg (Mac App Store). Signing identities and the
    // notarytool/provisioning credentials are read from env vars (see the scripts' headers).
    // Output: __artifacts/dist/ExifGlass_<version>_mac-arm64.{dmg,pkg}
    {
      "label": "pack-mac-arm64-app",
      "type": "process",
      "command": "bash",
      "args": [
        "${workspaceFolder}/__assets/mac/pack-app.sh"
      ],
      "problemMatcher": [],
      "dependsOn": [
        "publish-mac-arm64"
      ],
      "dependsOrder": "sequence",
      "group": "build"
    },
    {
      "label": "pack-mac-arm64-dmg",
      "type": "process",
      "command": "bash",
      "args": [
        "${workspaceFolder}/__assets/mac/pack-dmg.sh"
      ],
      "problemMatcher": [],
      "dependsOn": [
        "pack-mac-arm64-app"
      ],
      "dependsOrder": "sequence",
      "group": "build"
    },
    {
      "label": "pack-mac-arm64-pkg-appstore",
      "type": "process",
      "command": "bash",
      "args": [
        "${workspaceFolder}/__assets/mac/pack-pkg-appstore.sh"
      ],
      "problemMatcher": [],
      "dependsOn": [
        "pack-mac-arm64-app"
      ],
      "dependsOrder": "sequence",
      "group": "build"
    },


    // Flatpak pack (linux-x64 only): publishes a fresh AOT build, then builds a signed .flatpak.
    // Outputs to __artifacts/bundle/linux-flatpak. See __assets/linux/flatpak/README.md.
    {
      "label": "pack-linux-x64-flatpak",
      "type": "process",
      "command": "bash",
      "args": [
        "${workspaceFolder}/__assets/linux/pack-flatpak.sh"
      ],
      "options": {
        "env": {
          // Prompts on each run; leave blank to build an unsigned bundle.
          "GPG_KEY": "${input:gpgKey}"
        }
      },
      "problemMatcher": [],
      "dependsOn": [
        "build-exiftool-linux-x64"
      ],
      "dependsOrder": "sequence",
      "group": "build"
    },


    // Windows MSIX pack tasks. Each publishes a fresh self-contained AOT build, then
    // packs the app with logo-rendered tile artwork. See __assets/win/README.md.
    //
    //   Self-host (GitHub): a SIGNED .msix per architecture (pack-win-<arch>-msix).
    //                       Built UNSIGNED (with a warning) if no signing cert is found.
    //   Microsoft Store:    one UNSIGNED x64+arm64 .msixbundle (pack-win-msstore-msixbundle),
    //                       Store-reserved identity; the Store re-signs on submission.
    // Output: __artifacts/bundle/win/ExifGlass_<version>_win-<arch>.msix
    //         __artifacts/bundle/win/ExifGlass_<version>_win-msstore.msixbundle
    {
      "label": "pack-win-x64-msix",
      "type": "process",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/__assets/win/pack-msix.ps1",
        "-Platform",
        "x64",
        "-Sign"
      ],
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "pack-win-arm64-msix",
      "type": "process",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/__assets/win/pack-msix.ps1",
        "-Platform",
        "arm64",
        "-Sign"
      ],
      "problemMatcher": [],
      "group": "build"
    },
    // Microsoft Store: one UNSIGNED .msixbundle (x64 + arm64), Store-reserved identity.
    // The script builds both architectures, so this does NOT depend on the per-arch tasks.
    {
      "label": "pack-win-msstore-msixbundle",
      "type": "process",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/__assets/win/pack-msix.ps1",
        "-MsStore"
      ],
      "problemMatcher": [],
      "group": "build"
    }
  ],
  "inputs": [
    {
      // Used by "pack-linux-x64-flatpak". Not stored on disk -- VS Code only keeps
      // the last value for the current session. Blank => unsigned bundle.
      "id": "gpgKey",
      "type": "promptString",
      "description": "GPG key (email or key ID) to sign the .flatpak bundle. Leave blank for an unsigned bundle.",
      "default": ""
    }
  ]
}
