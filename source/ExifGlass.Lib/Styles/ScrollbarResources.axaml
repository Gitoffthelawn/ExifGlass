<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  WinUI 3-style ScrollBar resources  -->
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <!--  Thumb  -->
            <SolidColorBrush x:Key="PhScrollBarThumbFill" Color="#999999" />
            <SolidColorBrush x:Key="PhScrollBarThumbFillPointerOver" Color="#888888" />
            <SolidColorBrush x:Key="PhScrollBarThumbFillPressed" Color="#666666" />
            <SolidColorBrush x:Key="PhScrollBarThumbFillDisabled" Color="#30808080" />

            <!--  Track  -->
            <SolidColorBrush x:Key="PhScrollBarTrackFill" Color="Transparent" />
            <SolidColorBrush x:Key="PhScrollBarTrackFillPointerOver" Color="#08000000" />
            <SolidColorBrush x:Key="PhScrollBarTrackStroke" Color="Transparent" />
            <SolidColorBrush x:Key="PhScrollBarTrackStrokePointerOver" Color="Transparent" />

            <!--  Arrow buttons  -->
            <SolidColorBrush x:Key="PhScrollBarButtonArrowForeground" Color="#999999" />
            <SolidColorBrush x:Key="PhScrollBarButtonArrowForegroundPointerOver" Color="#888888" />
            <SolidColorBrush x:Key="PhScrollBarButtonArrowForegroundPressed" Color="#666666" />
            <SolidColorBrush x:Key="PhScrollBarButtonArrowForegroundDisabled" Color="#30808080" />
            <SolidColorBrush x:Key="PhScrollBarButtonBackground" Color="Transparent" />
            <SolidColorBrush x:Key="PhScrollBarButtonBackgroundPointerOver" Color="#08000000" />
            <SolidColorBrush x:Key="PhScrollBarButtonBackgroundPressed" Color="#10000000" />
            <SolidColorBrush x:Key="PhScrollBarButtonBackgroundDisabled" Color="Transparent" />
            <SolidColorBrush x:Key="PhScrollBarButtonBorderBrush" Color="Transparent" />
            <SolidColorBrush x:Key="PhScrollBarButtonBorderBrushPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="PhScrollBarButtonBorderBrushPressed" Color="Transparent" />
            <SolidColorBrush x:Key="PhScrollBarButtonBorderBrushDisabled" Color="Transparent" />

            <!--  Background  -->
            <SolidColorBrush x:Key="PhScrollBarBackground" Color="Transparent" />
            <SolidColorBrush x:Key="PhScrollBarBackgroundPointerOver" Color="#aaffffff" />
            <SolidColorBrush x:Key="PhScrollBarBorderBrush" Color="Transparent" />
            <SolidColorBrush x:Key="PhScrollBarForeground" Color="#6B6B6B" />
            <SolidColorBrush x:Key="PhScrollBarThumbBackgroundColor" Color="#999999" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
            <!--  Thumb  -->
            <SolidColorBrush x:Key="PhScrollBarThumbFill" Color="#BBBBBB" />
            <SolidColorBrush x:Key="PhScrollBarThumbFillPointerOver" Color="#CCCCCC" />
            <SolidColorBrush x:Key="PhScrollBarThumbFillPressed" Color="#DDDDDD" />
            <SolidColorBrush x:Key="PhScrollBarThumbFillDisabled" Color="#30808080" />

            <!--  Track  -->
            <SolidColorBrush x:Key="PhScrollBarTrackFill" Color="Transparent" />
            <SolidColorBrush x:Key="PhScrollBarTrackFillPointerOver" Color="#0CFFFFFF" />
            <SolidColorBrush x:Key="PhScrollBarTrackStroke" Color="Transparent" />
            <SolidColorBrush x:Key="PhScrollBarTrackStrokePointerOver" Color="Transparent" />

            <!--  Arrow buttons  -->
            <SolidColorBrush x:Key="PhScrollBarButtonArrowForeground" Color="#BBBBBB" />
            <SolidColorBrush x:Key="PhScrollBarButtonArrowForegroundPointerOver" Color="#CCCCCC" />
            <SolidColorBrush x:Key="PhScrollBarButtonArrowForegroundPressed" Color="#DDDDDD" />
            <SolidColorBrush x:Key="PhScrollBarButtonArrowForegroundDisabled" Color="#30808080" />
            <SolidColorBrush x:Key="PhScrollBarButtonBackground" Color="Transparent" />
            <SolidColorBrush x:Key="PhScrollBarButtonBackgroundPointerOver" Color="#0CFFFFFF" />
            <SolidColorBrush x:Key="PhScrollBarButtonBackgroundPressed" Color="#15FFFFFF" />
            <SolidColorBrush x:Key="PhScrollBarButtonBackgroundDisabled" Color="Transparent" />
            <SolidColorBrush x:Key="PhScrollBarButtonBorderBrush" Color="Transparent" />
            <SolidColorBrush x:Key="PhScrollBarButtonBorderBrushPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="PhScrollBarButtonBorderBrushPressed" Color="Transparent" />
            <SolidColorBrush x:Key="PhScrollBarButtonBorderBrushDisabled" Color="Transparent" />

            <!--  Background  -->
            <SolidColorBrush x:Key="PhScrollBarBackground" Color="Transparent" />
            <SolidColorBrush x:Key="PhScrollBarBackgroundPointerOver" Color="#33FFFFFF" />
            <SolidColorBrush x:Key="PhScrollBarBorderBrush" Color="Transparent" />
            <SolidColorBrush x:Key="PhScrollBarForeground" Color="#A0A0A0" />
            <SolidColorBrush x:Key="PhScrollBarThumbBackgroundColor" Color="#BBBBBB" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>


    <!--
        WinUI 3 metrics:
        - Track area is 14px wide (enough for hit-testing)
        - Thumb layout width is 6px (pill shape)
        - Collapsed: ScaleTransform shrinks thumb to ~2px visual
        - Expanded: RenderTransform=none shows the 6px pill
    -->
    <x:Double x:Key="PhScrollBarSize">14</x:Double>
    <x:Double x:Key="PhScrollBarThumbSize">8</x:Double>
    <x:Double x:Key="PhScrollBarButtonArrowIconLong">10</x:Double>
    <x:Double x:Key="PhScrollBarButtonArrowIconShort">7.5</x:Double>
    <x:Double x:Key="PhScrollBarTrackBorderThemeThickness">0</x:Double>

    <!--  Collapsed: scale the 6px thumb to ~2px (0.33 * 6 = 2)  -->
    <ScaleTransform x:Key="PhVerticalSmallScrollThumbScaleTransform" ScaleX="0.33" ScaleY="1" />
    <ScaleTransform x:Key="PhHorizontalSmallScrollThumbScaleTransform" ScaleX="1" ScaleY="0.33" />


    <!--  Thumb theme: pill-shaped with fully rounded corners  -->
    <ControlTheme x:Key="PhScrollBarThumb" TargetType="Thumb">
        <Setter Property="Background" Value="{DynamicResource PhScrollBarThumbFill}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Transitions">
            <Transitions>
                <CornerRadiusTransition Property="CornerRadius" Duration="0:0:0.1" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
            </Transitions>
        </Setter>

        <Style Selector="^:pointerover /template/ Border">
            <Setter Property="Background" Value="{DynamicResource PhScrollBarThumbFillPointerOver}" />
        </Style>
        <Style Selector="^:pressed /template/ Border">
            <Setter Property="Background" Value="{DynamicResource PhScrollBarThumbFillPressed}" />
        </Style>
        <Style Selector="^:disabled /template/ Border">
            <Setter Property="Background" Value="{DynamicResource PhScrollBarThumbFillDisabled}" />
        </Style>
    </ControlTheme>


    <!--  Page (track area) button: invisible hit-test area  -->
    <ControlTheme x:Key="PhScrollBarPageButton" TargetType="RepeatButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}" />
            </ControlTemplate>
        </Setter>
    </ControlTheme>


    <!--  Line (arrow) button: hidden by default, shown on expanded state  -->
    <ControlTheme x:Key="PhScrollBarLineButton" TargetType="RepeatButton">
        <Setter Property="Opacity" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource PhScrollBarButtonArrowForeground}" />
        <Setter Property="Template">
            <ControlTemplate>
                <ContentPresenter
                    x:Name="PART_ContentPresenter"
                    Background="{DynamicResource PhScrollBarButtonBackground}"
                    BorderBrush="{DynamicResource PhScrollBarButtonBorderBrush}"
                    Content="{TemplateBinding Content}" />
            </ControlTemplate>
        </Setter>
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
            </Transitions>
        </Setter>

        <Style Selector="^:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource PhScrollBarButtonArrowForegroundPointerOver}" />
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource PhScrollBarButtonBackgroundPointerOver}" />
                <Setter Property="BorderBrush" Value="{DynamicResource PhScrollBarButtonBorderBrushPointerOver}" />
            </Style>
        </Style>

        <Style Selector="^:pressed">
            <Setter Property="Foreground" Value="{DynamicResource PhScrollBarButtonArrowForegroundPressed}" />
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource PhScrollBarButtonBackgroundPressed}" />
                <Setter Property="BorderBrush" Value="{DynamicResource PhScrollBarButtonBorderBrushPressed}" />
            </Style>
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Foreground" Value="{DynamicResource PhScrollBarButtonArrowForegroundDisabled}" />
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource PhScrollBarButtonBackgroundDisabled}" />
                <Setter Property="BorderBrush" Value="{DynamicResource PhScrollBarButtonBorderBrushDisabled}" />
            </Style>
        </Style>
    </ControlTheme>


    <!--  Main ScrollBar ControlTheme (WinUI 3 style)  -->
    <ControlTheme x:Key="{x:Type ScrollBar}" TargetType="ScrollBar">
        <Setter Property="MinWidth" Value="{DynamicResource PhScrollBarSize}" />
        <Setter Property="MinHeight" Value="{DynamicResource PhScrollBarSize}" />
        <Setter Property="Background" Value="{DynamicResource PhScrollBarBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource PhScrollBarForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PhScrollBarBorderBrush}" />

        <!--  ===== VERTICAL =====  -->
        <Style Selector="^:vertical">
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid x:Name="Root">
                        <Border
                            x:Name="VerticalRoot"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            CornerRadius="6">
                            <Grid RowDefinitions="Auto,*,Auto">
                                <Rectangle
                                    x:Name="TrackRect"
                                    Grid.RowSpan="3"
                                    Fill="{DynamicResource PhScrollBarTrackFill}"
                                    Opacity="0"
                                    RadiusX="6"
                                    RadiusY="6"
                                    Stroke="{DynamicResource PhScrollBarTrackStroke}"
                                    StrokeThickness="{DynamicResource PhScrollBarTrackBorderThemeThickness}">
                                    <Rectangle.Transitions>
                                        <Transitions>
                                            <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
                                        </Transitions>
                                    </Rectangle.Transitions>
                                </Rectangle>

                                <RepeatButton
                                    Name="PART_LineUpButton"
                                    Grid.Row="0"
                                    Height="{DynamicResource PhScrollBarSize}"
                                    MinWidth="{DynamicResource PhScrollBarSize}"
                                    HorizontalAlignment="Center"
                                    AutomationProperties.Name="Line up"
                                    Focusable="False"
                                    Theme="{StaticResource PhScrollBarLineButton}">
                                    <PathIcon
                                        Width="{DynamicResource PhScrollBarButtonArrowIconLong}"
                                        Height="{DynamicResource PhScrollBarButtonArrowIconShort}"
                                        Data="M 3,9.5 L 7,2.8 Q 8,1 9,2.8 L 13,9.5 Q 14,11.5 12,11.5 L 4,11.5 Q 2,11.5 3,9.5 Z"
                                        Foreground="{CompiledBinding $parent[RepeatButton].Foreground}" />
                                </RepeatButton>

                                <Track
                                    Grid.Row="1"
                                    DeferThumbDrag="{TemplateBinding ScrollViewer.IsDeferredScrollingEnabled}"
                                    IsDirectionReversed="True"
                                    Maximum="{TemplateBinding Maximum}"
                                    Minimum="{TemplateBinding Minimum}"
                                    Orientation="{TemplateBinding Orientation}"
                                    ViewportSize="{TemplateBinding ViewportSize}"
                                    Value="{TemplateBinding Value,
                                                            Mode=TwoWay}">
                                    <Track.DecreaseButton>
                                        <RepeatButton
                                            Name="PART_PageUpButton"
                                            AutomationProperties.Name="Page up"
                                            Classes="largeIncrease"
                                            Focusable="False"
                                            Theme="{StaticResource PhScrollBarPageButton}" />
                                    </Track.DecreaseButton>
                                    <Track.IncreaseButton>
                                        <RepeatButton
                                            Name="PART_PageDownButton"
                                            AutomationProperties.Name="Page down"
                                            Classes="largeIncrease"
                                            Focusable="False"
                                            Theme="{StaticResource PhScrollBarPageButton}" />
                                    </Track.IncreaseButton>
                                    <!--  Thumb: 6px layout width, visually scaled to ~2px when collapsed  -->
                                    <Thumb
                                        Width="{DynamicResource PhScrollBarThumbSize}"
                                        MinHeight="{DynamicResource PhScrollBarSize}"
                                        AutomationProperties.Name="Position"
                                        CornerRadius="4"
                                        RenderTransform="{DynamicResource PhVerticalSmallScrollThumbScaleTransform}"
                                        RenderTransformOrigin="100%,50%"
                                        Theme="{StaticResource PhScrollBarThumb}" />
                                </Track>

                                <RepeatButton
                                    Name="PART_LineDownButton"
                                    Grid.Row="2"
                                    Height="{DynamicResource PhScrollBarSize}"
                                    MinWidth="{DynamicResource PhScrollBarSize}"
                                    HorizontalAlignment="Center"
                                    AutomationProperties.Name="Line down"
                                    Focusable="False"
                                    Theme="{StaticResource PhScrollBarLineButton}">
                                    <PathIcon
                                        Width="{DynamicResource PhScrollBarButtonArrowIconLong}"
                                        Height="{DynamicResource PhScrollBarButtonArrowIconShort}"
                                        Data="M 13,2.5 L 9,9.2 Q 8,11 7,9.2 L 3,2.5 Q 2,0.5 4,0.5 L 12,0.5 Q 14,0.5 13,2.5 Z"
                                        Foreground="{CompiledBinding $parent[RepeatButton].Foreground}" />
                                </RepeatButton>
                            </Grid>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>

        <!--  ===== HORIZONTAL =====  -->
        <Style Selector="^:horizontal">
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid x:Name="Root">
                        <Border
                            x:Name="HorizontalRoot"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            CornerRadius="6">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Rectangle
                                    x:Name="TrackRect"
                                    Grid.ColumnSpan="3"
                                    Fill="{DynamicResource PhScrollBarTrackFill}"
                                    Opacity="0"
                                    RadiusX="6"
                                    RadiusY="6"
                                    Stroke="{DynamicResource PhScrollBarTrackStroke}"
                                    StrokeThickness="{DynamicResource PhScrollBarTrackBorderThemeThickness}">
                                    <Rectangle.Transitions>
                                        <Transitions>
                                            <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
                                        </Transitions>
                                    </Rectangle.Transitions>
                                </Rectangle>

                                <RepeatButton
                                    Name="PART_LineUpButton"
                                    Grid.Column="0"
                                    Width="{DynamicResource PhScrollBarSize}"
                                    MinHeight="{DynamicResource PhScrollBarSize}"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name="Column left"
                                    Focusable="False"
                                    Theme="{StaticResource PhScrollBarLineButton}">
                                    <PathIcon
                                        Width="{DynamicResource PhScrollBarButtonArrowIconShort}"
                                        Height="{DynamicResource PhScrollBarButtonArrowIconLong}"
                                        Data="M 9.5,3 L 2.8,7 Q 1,8 2.8,9 L 9.5,13 Q 11.5,14 11.5,12 L 11.5,4 Q 11.5,2 9.5,3 Z"
                                        Foreground="{CompiledBinding $parent[RepeatButton].Foreground}" />
                                </RepeatButton>

                                <Track
                                    Grid.Column="1"
                                    DeferThumbDrag="{TemplateBinding ScrollViewer.IsDeferredScrollingEnabled}"
                                    Maximum="{TemplateBinding Maximum}"
                                    Minimum="{TemplateBinding Minimum}"
                                    Orientation="{TemplateBinding Orientation}"
                                    ViewportSize="{TemplateBinding ViewportSize}"
                                    Value="{TemplateBinding Value,
                                                            Mode=TwoWay}">
                                    <Track.DecreaseButton>
                                        <RepeatButton
                                            Name="PART_PageUpButton"
                                            AutomationProperties.Name="Page left"
                                            Classes="largeIncrease"
                                            Focusable="False"
                                            Theme="{StaticResource PhScrollBarPageButton}" />
                                    </Track.DecreaseButton>
                                    <Track.IncreaseButton>
                                        <RepeatButton
                                            Name="PART_PageDownButton"
                                            AutomationProperties.Name="Page right"
                                            Classes="largeIncrease"
                                            Focusable="False"
                                            Theme="{StaticResource PhScrollBarPageButton}" />
                                    </Track.IncreaseButton>
                                    <!--  Thumb: 6px layout height, visually scaled to ~2px when collapsed  -->
                                    <Thumb
                                        Height="{DynamicResource PhScrollBarThumbSize}"
                                        MinWidth="{DynamicResource PhScrollBarSize}"
                                        AutomationProperties.Name="Position"
                                        CornerRadius="4"
                                        RenderTransform="{DynamicResource PhHorizontalSmallScrollThumbScaleTransform}"
                                        RenderTransformOrigin="50%,100%"
                                        Theme="{StaticResource PhScrollBarThumb}" />
                                </Track>

                                <RepeatButton
                                    Name="PART_LineDownButton"
                                    Grid.Column="2"
                                    Width="{DynamicResource PhScrollBarSize}"
                                    MinHeight="{DynamicResource PhScrollBarSize}"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name="Column right"
                                    Focusable="False"
                                    Theme="{StaticResource PhScrollBarLineButton}">
                                    <PathIcon
                                        Width="{DynamicResource PhScrollBarButtonArrowIconShort}"
                                        Height="{DynamicResource PhScrollBarButtonArrowIconLong}"
                                        Data="M 2.5,3 L 9.2,7 Q 11,8 9.2,9 L 2.5,13 Q 0.5,14 0.5,12 L 0.5,4 Q 0.5,2 2.5,3 Z"
                                        Foreground="{CompiledBinding $parent[RepeatButton].Foreground}" />
                                </RepeatButton>
                            </Grid>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>

        <!--  ===== EXPANDED STATE (pointer over scrollbar area) =====  -->
        <Style Selector="^[IsExpanded=true]">
            <Style Selector="^ /template/ Border#VerticalRoot">
                <Setter Property="Background" Value="{DynamicResource PhScrollBarBackgroundPointerOver}" />
            </Style>
            <Style Selector="^ /template/ Border#HorizontalRoot">
                <Setter Property="Background" Value="{DynamicResource PhScrollBarBackgroundPointerOver}" />
            </Style>
            <Style Selector="^ /template/ Rectangle#TrackRect">
                <Setter Property="Fill" Value="{DynamicResource PhScrollBarTrackFillPointerOver}" />
                <Setter Property="Stroke" Value="{DynamicResource PhScrollBarTrackStrokePointerOver}" />
                <Setter Property="Opacity" Value="1" />
            </Style>
            <!--  Expanded: remove scale transform to show full 6px pill thumb  -->
            <Style Selector="^ /template/ Thumb">
                <Setter Property="Background" Value="{DynamicResource PhScrollBarThumbBackgroundColor}" />
                <Setter Property="RenderTransform" Value="none" />
            </Style>
            <Style Selector="^ /template/ RepeatButton">
                <Setter Property="Opacity" Value="1" />
            </Style>
        </Style>
    </ControlTheme>

</ResourceDictionary>
