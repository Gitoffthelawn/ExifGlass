<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  Open animation: subtle scale + fade, growing from the top edge where the menu is anchored  -->
    <Style Selector="MenuFlyoutPresenter, ContextMenu, FlyoutPresenter, ToolTip, Popup">
        <!--  initialize the transform so the animator has something to target  -->
        <Setter Property="RenderTransformOrigin" Value="50%,0%" />
        <Setter Property="RenderTransform">
            <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
        </Setter>

        <Style.Animations>
            <Animation Easing="CubicEaseOut" Duration="0:0:0.15">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.0" />
                    <Setter Property="ScaleTransform.ScaleX" Value="0.95" />
                    <Setter Property="ScaleTransform.ScaleY" Value="0.95" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1.0" />
                    <Setter Property="ScaleTransform.ScaleX" Value="1.0" />
                    <Setter Property="ScaleTransform.ScaleY" Value="1.0" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>


    <!--  Dropdown shadow  -->
    <Style Selector="MenuFlyoutPresenter > Border, ContextMenu > Border, FlyoutPresenter > Border, ToolTip > Border, Popup > Border">
        <Setter Property="Margin" Value="6, 1, 6, 12" />
        <Setter Property="BoxShadow" Value="{DynamicResource MenuShadow}" />
    </Style>


    <!--  Menu item  -->
    <Style Selector="MenuItem">
        <Setter Property="Margin" Value="4, 0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />


        <!--  Menu item content  -->
        <Style Selector="^ /template/ Border#PART_LayoutRoot">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.05" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.05" />
                </Transitions>
            </Setter>
        </Style>

        <!--  Fixed: check mark is cut off  -->
        <Style Selector="^:checked:toggle /template/ ContentControl#PART_ToggleIconPresenter Path">
            <Setter Property="Width" Value="14" />
            <Setter Property="Stretch" Value="Uniform" />
        </Style>
    </Style>

</Styles>
