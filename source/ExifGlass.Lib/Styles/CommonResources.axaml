<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="PhCardBackgroundBrush" Color="#AAFBFBFB" />
            <SolidColorBrush x:Key="PhCardBorderBrush" Color="#22000000" />
            <SolidColorBrush x:Key="PhGroupHeaderBackgroundBrush" Color="#0C000000" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="PhCardBackgroundBrush" Color="#AA111111" />
            <SolidColorBrush x:Key="PhCardBorderBrush" Color="#22FFFFFF" />
            <SolidColorBrush x:Key="PhGroupHeaderBackgroundBrush" Color="#14FFFFFF" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>


    <x:Double x:Key="ControlContentThemeFontSize">14</x:Double>

    <!--  Corner Radius  -->
    <CornerRadius x:Key="ControlCornerRadius">7</CornerRadius>
    <CornerRadius x:Key="OverlayCornerRadius">10</CornerRadius>

    <!--  Tooltip  -->
    <x:Double x:Key="ToolTipContentThemeFontSize">14</x:Double>
    <x:Double x:Key="ToolTipContentMaxWidth">500</x:Double>

    <!--  Text selection color  -->
    <x:Double x:Key="TextContentMaxWidth">600</x:Double>
    <SolidColorBrush
        x:Key="TextControlSelectionHighlightColor"
        Opacity="0.4"
        Color="{DynamicResource SystemAccentColor}" />


    <SolidColorBrush
        x:Key="SelectionColorBrush"
        Opacity="0.3"
        Color="{DynamicResource SystemAccentColor}" />

</ResourceDictionary>
