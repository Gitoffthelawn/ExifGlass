<views:StyledWindow
    x:Class="ExifGlass.Views.UpdateWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:ExifGlass.Views"
    xmlns:vm="using:ExifGlass.ViewModels"
    mc:Ignorable="d"
    d:DesignHeight="420"
    d:DesignWidth="460"
    x:DataType="vm:UpdateViewModel"
    Title="Update available"
    Width="460"
    CanResize="False"
    Icon="/Assets/exifglass_icon_512.ico"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner">

    <Window.KeyBindings>
        <KeyBinding Command="{Binding CloseCommand}" Gesture="Escape" />
    </Window.KeyBindings>

    <Grid RowDefinitions="*,Auto">
        <StackPanel
            Grid.Row="0"
            Margin="24,24,24,12"
            Spacing="8">

            <StackPanel Orientation="Horizontal" Spacing="16">
                <Image
                    Width="56"
                    Height="56"
                    VerticalAlignment="Top"
                    Source="/Assets/exifglass_icon_512.ico" />
                <StackPanel VerticalAlignment="Center" Spacing="2">
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource SystemAccentColor}"
                        Text="A new version is available" />
                    <TextBlock Text="{Binding Title}" TextWrapping="Wrap" />
                </StackPanel>
            </StackPanel>

            <StackPanel
                Margin="0,10,0,0"
                Orientation="Horizontal"
                Spacing="6">
                <TextBlock Opacity="0.8" Text="Current version:" />
                <TextBlock FontWeight="SemiBold" Text="{Binding CurrentVersion}" />
                <TextBlock
                    Margin="12,0,0,0"
                    Opacity="0.8"
                    Text="New version:" />
                <TextBlock
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource SystemAccentColor}"
                    Text="{Binding NewVersion}" />
            </StackPanel>

            <TextBlock
                IsVisible="{Binding PublishedDate, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Opacity="0.8"
                Text="{Binding PublishedDate, StringFormat='Released {0}'}" />

            <Border
                Margin="0,6,0,0"
                Padding="12,10"
                Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                CornerRadius="6">
                <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto">
                    <SelectableTextBlock Text="{Binding Notes}" TextWrapping="Wrap" />
                </ScrollViewer>
            </Border>

            <Button
                Padding="0"
                HorizontalAlignment="Left"
                Background="Transparent"
                BorderThickness="0"
                Command="{Binding OpenChangelogCommand}"
                Cursor="Hand"
                IsVisible="{Binding HasChangelog}">
                <TextBlock
                    Foreground="{DynamicResource SystemAccentColor}"
                    Text="View full changelog"
                    TextDecorations="Underline" />
            </Button>

        </StackPanel>

        <Border Grid.Row="1" Padding="24,12">
            <StackPanel
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="10">
                <Button
                    MinWidth="120"
                    HorizontalContentAlignment="Center"
                    Classes="accent"
                    Command="{Binding DownloadCommand}"
                    Content="Download" />
                <Button
                    MinWidth="88"
                    HorizontalContentAlignment="Center"
                    Command="{Binding CloseCommand}"
                    Content="Later" />
            </StackPanel>
        </Border>
    </Grid>
</views:StyledWindow>
