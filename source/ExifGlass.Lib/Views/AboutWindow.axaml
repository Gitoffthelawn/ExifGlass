<views:StyledWindow
    x:Class="ExifGlass.Views.AboutWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:ExifGlass.Views"
    xmlns:vm="using:ExifGlass.ViewModels"
    mc:Ignorable="d"
    d:DesignHeight="520"
    d:DesignWidth="440"
    x:DataType="vm:AboutViewModel"
    Title="About"
    Width="500"
    CanMinimize="False"
    CanResize="False"
    Icon="/Assets/exifglass_icon_512.ico"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner">

    <Window.KeyBindings>
        <KeyBinding Command="{Binding CloseCommand}" Gesture="Escape" />
    </Window.KeyBindings>

    <Grid RowDefinitions="*,Auto">
        <StackPanel
            Grid.Row="0"
            Margin="24,24,24,12"
            Spacing="6">

            <StackPanel Spacing="20">
                <Image
                    Width="96"
                    Height="96"
                    VerticalAlignment="Top"
                    Source="/Assets/exifglass_icon_512.ico" />
                <StackPanel Spacing="2">
                    <SelectableTextBlock
                        FontSize="24"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource SystemAccentColor}"
                        Text="ExifGlass"
                        TextAlignment="Center" />
                    <SelectableTextBlock Text="EXIF Metadata Viewing Tool" TextAlignment="Center" />

                </StackPanel>
            </StackPanel>


            <StackPanel
                Margin="0,14,0,0"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="6">
                <SelectableTextBlock FontWeight="SemiBold" Text="Version" />
                <SelectableTextBlock FontWeight="SemiBold" Text="{Binding Version}" />
            </StackPanel>
            <Button
                Padding="0"
                HorizontalAlignment="Center"
                Background="Transparent"
                BorderThickness="0"
                Command="{Binding OpenWebsiteCommand}"
                Cursor="Hand">
                <TextBlock
                    Foreground="{DynamicResource SystemAccentColor}"
                    Text="{Binding WebsiteUrl}"
                    TextAlignment="Center"
                    TextDecorations="Underline" />
            </Button>


            <StackPanel Margin="0,14,0,0">
                <SelectableTextBlock Text="Copyright © 2023 – 2026 by Dương Diệu Pháp." TextAlignment="Center" />
                <SelectableTextBlock Text="All rights reserved." TextAlignment="Center" />
            </StackPanel>


            <Button
                Margin="0,12,0,0"
                Padding="8,8,12,8"
                HorizontalAlignment="Center"
                Command="{Binding OpenStoreCommand}"
                IsVisible="{OnPlatform Default=False,
                                       Windows=True}">
                <StackPanel
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="8">
                    <TextBlock FontSize="32" Text="🛍️" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontWeight="SemiBold" Text="Get ExifGlass" />
                        <TextBlock FontWeight="SemiBold" Text="from Microsoft Store" />
                    </StackPanel>
                </StackPanel>
            </Button>


            <TextBlock
                Margin="0,14,0,0"
                FontWeight="SemiBold"
                Text="Credits"
                TextAlignment="Center" />
            <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">
                <Border
                    Padding="8"
                    Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                    CornerRadius="4">
                    <StackPanel Spacing="8">
                        <StackPanel>
                            <SelectableTextBlock FontWeight="SemiBold" Text="Avalonia" />
                            <SelectableTextBlock Text="MIT license. © The AvaloniaUI project." />
                        </StackPanel>
                        <StackPanel>
                            <SelectableTextBlock FontWeight="SemiBold" Text="ExifTool" />
                            <SelectableTextBlock Text="Artistic license. © Phil Harvey." />
                        </StackPanel>
                        <StackPanel>
                            <SelectableTextBlock FontWeight="SemiBold" Text="ProDataGrid" />
                            <SelectableTextBlock Text="MIT license. © Wiesław Šoltés." />
                        </StackPanel>
                        <StackPanel>
                            <SelectableTextBlock FontWeight="SemiBold" Text="CliWrap" />
                            <SelectableTextBlock Text="MIT license. © Oleksii Holub." />
                        </StackPanel>
                        <StackPanel>
                            <SelectableTextBlock FontWeight="SemiBold" Text="CommunityToolkit.Mvvm" />
                            <SelectableTextBlock Text="MIT license. © .NET Foundation and Contributors." />
                        </StackPanel>
                        <StackPanel>
                            <SelectableTextBlock FontWeight="SemiBold" Text="ImageGlass.SDK" />
                            <SelectableTextBlock Text="MIT license. © Dương Diệu Pháp." />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </ScrollViewer>

        </StackPanel>


        <Border Grid.Row="1" Padding="24,12">
            <StackPanel
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="10">
                <Button
                    MinWidth="120"
                    HorizontalContentAlignment="Center"
                    Command="{Binding CheckForUpdateCommand}"
                    Content="Check for update" />
                <Button
                    MinWidth="88"
                    HorizontalContentAlignment="Center"
                    Classes="accent"
                    Command="{Binding CloseCommand}"
                    Content="Close" />
            </StackPanel>
        </Border>
    </Grid>
</views:StyledWindow>
