<views:StyledWindow xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:views="using:ExifGlass.Views"
                    xmlns:vm="using:ExifGlass.ViewModels"
                    mc:Ignorable="d" d:DesignWidth="380" d:DesignHeight="200"
                    x:Class="ExifGlass.Views.MessageBox"
                    x:DataType="vm:MessageBoxViewModel"
                    MinWidth="360" MaxWidth="520"
                    CanResize="False"
                    SizeToContent="WidthAndHeight"
                    WindowStartupLocation="CenterOwner"
                    Icon="/Assets/exifglass_icon_512.ico">

    <Window.KeyBindings>
        <KeyBinding Gesture="Escape" Command="{Binding OkCommand}" />
        <KeyBinding Gesture="Enter" Command="{Binding OkCommand}" />
    </Window.KeyBindings>

    <Grid RowDefinitions="*,Auto">
        <StackPanel Grid.Row="0" Margin="20" Spacing="10">
            <TextBlock FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource SystemAccentColor}"
                       TextWrapping="Wrap"
                       Text="{Binding Heading}" />
            <SelectableTextBlock TextWrapping="Wrap" Text="{Binding Message}" />
        </StackPanel>

        <Border Grid.Row="1" Padding="20,12">
            <Button MinWidth="88"
                    HorizontalAlignment="Right"
                    HorizontalContentAlignment="Center"
                    Classes="accent"
                    Command="{Binding OkCommand}"
                    Content="OK" />
        </Border>
    </Grid>
</views:StyledWindow>
